  area.innerHTML='';
  const qbox=document.createElement('div'); qbox.style.cssText='background:var(--lav1);border-radius:16px;padding:20px;border:2px solid var(--lav3);';
  qbox.innerHTML=`<div style="font-weight:800;font-size:17px;color:var(--deep);margin-bottom:16px;"> Q${quizIdx+1}. ${q.q}</div>`;
  q.opts.forEach((o,i)=>{
    const b=document.createElement('button');
    b.style.cssText='display:block;width:100%;text-align:left;background:white;border:2.5px solid var(--lav3);border-radius:12px;padding:12px 16px;font-size:15px;font-weight:700;color:var(--textd);margin-bottom:8px;cursor:pointer;transition:all 0.2s;font-family:Nunito,sans-serif;';
    b.textContent=(i===0?'A':i===1?'B':i===2?'C':'D')+'. '+o;
    b.onmouseover=()=>{ if(!b.disabled) b.style.background='var(--lav1)'; };
    b.onmouseout=()=>{ if(!b.disabled) b.style.background='white'; };
    b.onclick=()=>{
      document.querySelectorAll('#quiz-area button').forEach(x=>x.disabled=true);
      if (i===q.a) {
        b.style.background='var(--mint2)'; b.style.borderColor='#10b981'; b.style.color='#065f46';
        quizCorrect++; showNotif('✅ Correct! 🎉');
      } else {
        b.style.background='#fee2e2'; b.style.borderColor='#ef4444'; b.style.color='#dc2626';
        document.querySelectorAll('#quiz-area button')[q.a].style.background='var(--mint2)';
        document.querySelectorAll('#quiz-area button')[q.a].style.borderColor='#10b981';
        showNotif('❌ The answer was: ' + q.opts[q.a]);
      }
      document.getElementById('quiz-score').textContent='Score: '+quizCorrect+' / '+(quizIdx+1);
    };
    qbox.appendChild(b);
  });
  area.appendChild(qbox);
}
function nextQuiz() {
  quizIdx=(quizIdx+1)%quizData.length;
  buildQuiz();
  if (quizIdx===0 && quizCorrect>0) { addXP(25,'quiz'); }
}

