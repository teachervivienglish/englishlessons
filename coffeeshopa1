let timerInterval=null, timerSecs=60;
function setTimer(s) { clearInterval(timerInterval); timerInterval=null; timerSecs=s; updateTimer(); document.getElementById('timer-display').classList.remove('warn'); }
function updateTimer() {
  const m=String(Math.floor(timerSecs/60)).padStart(2,'0');
  const s=String(timerSecs%60).padStart(2,'0');
  document.getElementById('timer-display').textContent=m+':'+s;
  document.getElementById('timer-display').classList.toggle('warn', timerSecs<=10);
}
function startTimer() {
  if (timerInterval) return;
  timerInterval=setInterval(()=>{ if (timerSecs<=0) { clearInterval(timerInterval); timerInterval=null; showNotif('⏰ Time is up!'); return; } timerSecs--; updateTimer(); },1000);
}
function pauseTimer() { clearInterval(timerInterval); timerInterval=null; }
function resetTimer()  { clearInterval(timerInterval); timerInterval=null; timerSecs=60; updateTimer(); document.getElementById('timer-display').classList.remove('warn'); }

