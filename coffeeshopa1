// ════════════════════════════════════════
// SENTENCE ORDER GAME
// ════════════════════════════════════════
let sentIdx=0, sentPlaced=[];
function buildSentenceGame() {
  sentPlaced=[];
  const sent=sentences[sentIdx];
  const area=document.getElementById('sentence-game-area');
  area.innerHTML='';
  document.getElementById('sentence-feedback').textContent='';
  // chips bank
  const bank=document.createElement('div'); bank.className='word-chips'; bank.id='word-bank';
  const shuffled=[...sent.words].sort(()=>Math.random()-0.5);
  shuffled.forEach((w,i)=>{
    const c=document.createElement('div'); c.className='word-chip'; c.textContent=w; c.dataset.word=w; c.dataset.idx=i;
    c.onclick=()=>placeWord(c);
    bank.appendChild(c);
  });
  // slot
  const slot=document.createElement('div'); slot.className='answer-slot'; slot.id='sent-slot';
  const lbl=document.createElement('div'); lbl.style.cssText='font-size:12px;font-weight:800;color:var(--purple);margin-bottom:6px;letter-spacing:1px;';
  lbl.textContent='YOUR SENTENCE 👇';
  area.appendChild(lbl); area.appendChild(slot); area.appendChild(bank);
}
function placeWord(chip) {
  if (chip.classList.contains('used')) return;
  chip.classList.add('used');
  sentPlaced.push(chip.dataset.word);
  const slot=document.getElementById('sent-slot');
  const pc=document.createElement('div'); pc.className='placed-chip'; pc.textContent=chip.dataset.word;
  pc.dataset.word=chip.dataset.word; pc.dataset.chipIdx=chip.dataset.idx;
  pc.onclick=()=>removeWord(pc, chip);
  slot.appendChild(pc);
}
function removeWord(pc, chip) {
  sentPlaced.splice(sentPlaced.indexOf(pc.dataset.word),1);
  pc.remove(); chip.classList.remove('used');
}
function checkSentence() {
  const fb=document.getElementById('sentence-feedback');
  const correct=sentences[sentIdx].correct;
  const attempt=sentPlaced.join(' ');
  if (attempt===correct) {
    fb.innerHTML='<span style="color:#10b981;">✅ Correct! 🎉 Amazing, Duda!</span>';
    addXP(20,'sentence_'+sentIdx);
  } else {
    fb.innerHTML='<span style="color:#ef4444;">❌ Not quite! Try again — or check the order!</span>';
  }
}
function nextSentence() { sentIdx=(sentIdx+1)%sentences.length; buildSentenceGame(); }
function resetSentence() { buildSentenceGame(); }

