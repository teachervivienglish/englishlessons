  if (xp >= 150) label = '🧁 Café Star';
  if (xp >= 200) label = '🏆 Café Master!';
  document.getElementById('level-label').textContent = label;
  document.getElementById('xp-hint').textContent = '🎉 +'+ amount +' XP earned!';
  showNotif('⭐ +' + amount + ' XP! ' + label);
  if (xp >= 200) { setTimeout(()=>showReward('🎉🎊⭐','Café Master!','You completed the whole lesson! You are AMAZING, Duda! 🌟'), 500); launchConfetti(); }
}

