<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Duda's Café English Class 🧁</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400&family=Fredoka+One&display=swap" rel="stylesheet">
<style>
:root {
  --lav1:   #f3eeff;
  --lav2:   #e8daff;
  --lav3:   #d4b8ff;
  --lav4:   #b68fff;
  --purple: #8b5cf6;
  --deep:   #6d28d9;
  --deeper: #4c1d95;
  --pink:   #e879f9;
  --pink2:  #f0abfc;
  --pink3:  #fdf4ff;
  --mint:   #a7f3d0;
  --mint2:  #d1fae5;
  --yellow: #fde68a;
  --yellow2:#fffbeb;
  --coral:  #fca5a5;
  --text:   #3b1f6e;
  --textd:  #1e0a40;
  --gray:   #f5f3ff;
  --shadow: 0 6px 24px rgba(139,92,246,0.18);
  --shadowb: 0 4px 16px rgba(139,92,246,0.28);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Nunito', sans-serif;
  background: linear-gradient(135deg, #f8f4ff 0%, #fdf0ff 50%, #f0f4ff 100%);
  color: var(--text);
  min-height: 100vh;
  font-size: 16px;
}
.app { max-width: 1060px; margin: 0 auto; padding: 20px 14px 60px; }

/* ═══ HEADER ═══ */
.header {
  background: linear-gradient(135deg, var(--deep) 0%, #a855f7 50%, var(--pink) 100%);
  border-radius: 28px;
  padding: 32px 24px 28px;
  text-align: center;
  box-shadow: 0 10px 40px rgba(109,40,217,0.4);
  margin-bottom: 22px;
  position: relative;
  overflow: hidden;
}
.header::before {
  content: '☕ 🧁 🍰 🥐 🍵 🧃 🫖 🍪';
  position: absolute; top: 8px; left: 0; right: 0;
  font-size: 22px; letter-spacing: 8px; opacity: 0.2;
  white-space: nowrap; overflow: hidden;
}
.header h1 {
  font-family: 'Fredoka One', cursive;
  font-size: 48px; color: white;
  text-shadow: 0 3px 12px rgba(0,0,0,0.2);
  line-height: 1; margin-bottom: 8px;
}
.header h1 span { color: var(--yellow); }
.header-sub {
  font-size: 16px; color: rgba(255,255,255,0.88);
  font-weight: 600; letter-spacing: 0.5px;
}
.header-badges {
  display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
  margin-top: 16px;
}
.badge {
  background: rgba(255,255,255,0.22);
  border: 2px solid rgba(255,255,255,0.4);
  color: white; border-radius: 999px;
  padding: 6px 16px; font-size: 13px; font-weight: 700;
  backdrop-filter: blur(4px);
}

/* ═══ PROGRESS ═══ */
.progress-wrap {
  background: white; border-radius: 20px;
  padding: 16px 22px; margin-bottom: 18px;
  box-shadow: var(--shadow);
  border: 2px solid var(--lav3);
}
.progress-bar { background: var(--lav2); border-radius: 999px; height: 14px; overflow: hidden; margin: 8px 0; }
.progress-fill {
  background: linear-gradient(90deg, var(--purple), var(--pink));
  height: 100%; border-radius: 999px;
  transition: width 0.5s ease;
  position: relative;
}
.progress-fill::after {
  content: '⭐'; position: absolute; right: -4px; top: -8px; font-size: 18px;
}
.xp-counter {
  font-family: 'Fredoka One', cursive;
  font-size: 18px; color: var(--deep);
}
.xp-counter span { color: var(--pink); }

/* ═══ TABS ═══ */
.tabs {
  display: flex; gap: 6px; flex-wrap: wrap;
  margin-bottom: 20px; justify-content: center;
}
.tab-btn {
  padding: 10px 18px; border-radius: 999px;
  border: 2.5px solid var(--lav3);
  background: white; font-weight: 800; font-size: 14px;
  cursor: pointer; color: var(--purple);
  transition: all 0.2s ease; font-family: 'Nunito', sans-serif;
}
.tab-btn:hover { border-color: var(--purple); background: var(--lav1); }
.tab-btn.active {
  background: linear-gradient(135deg, var(--deep), var(--purple));
  color: white; border-color: var(--deep);
  box-shadow: 0 4px 14px rgba(109,40,217,0.35);
}
.tab-content { display: none; }
.tab-content.active { display: block; }

/* ═══ CARDS ═══ */
.card {
  background: white; border-radius: 22px;
  border: 2.5px solid var(--lav3);
  padding: 24px; margin-bottom: 18px;
  box-shadow: var(--shadow);
}
.card-purple { border-color: var(--purple); background: linear-gradient(160deg,white,var(--lav1)); }
.card-pink   { border-color: var(--pink);   background: linear-gradient(160deg,white,var(--pink3)); }
.card-mint   { border-color: #6ee7b7;       background: linear-gradient(160deg,white,var(--mint2)); }
.card-yellow { border-color: #f59e0b;        background: linear-gradient(160deg,white,var(--yellow2)); }
.card h2 {
  font-family: 'Fredoka One', cursive;
  font-size: 26px; color: var(--deep); margin-bottom: 14px;
  display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
}
.card h3 {
  font-family: 'Fredoka One', cursive;
  font-size: 19px; color: var(--purple); margin: 16px 0 8px;
}
.section-label {
  font-size: 11px; font-weight: 800; letter-spacing: 2px;
  text-transform: uppercase; color: var(--purple); margin-bottom: 6px;
}

/* ═══ VOCAB VISUAL GRID ═══ */
.vocab-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(145px, 1fr));
  gap: 14px; margin-top: 14px;
}
.vocab-card {
  background: white; border: 2.5px solid var(--lav3);
  border-radius: 18px; padding: 14px 10px;
  text-align: center; cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 3px 10px rgba(139,92,246,0.1);
}
.vocab-card:hover { transform: translateY(-4px); box-shadow: var(--shadowb); border-color: var(--purple); }
.vocab-card .emoji { font-size: 42px; display: block; margin-bottom: 6px; }
.vocab-card .word { font-weight: 800; font-size: 15px; color: var(--deep); display: block; }
.vocab-card .pron {
  font-size: 12px; color: var(--purple); font-style: italic;
  display: block; margin-top: 2px; background: var(--lav1);
  border-radius: 6px; padding: 2px 4px; margin-top: 4px;
}
.vocab-card .pt  { font-size: 11px; color: #888; display: block; margin-top: 3px; }
.vocab-card.clicked { background: var(--lav2); border-color: var(--purple); }

/* ═══ PRONUNCIATION BLOCK ═══ */
.pron-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px; margin-top: 12px;
}
.pron-item {
  background: var(--lav1); border: 2px solid var(--lav3);
  border-radius: 14px; padding: 14px;
  display: flex; align-items: center; gap: 12px;
}
.pron-item .big-emoji { font-size: 30px; flex-shrink: 0; }
.pron-item .pron-info { flex: 1; }
.pron-item .pron-word { font-weight: 800; font-size: 15px; color: var(--deep); }
.pron-item .pron-ipa  { font-size: 13px; color: var(--purple); font-family: monospace; background: white; border-radius: 6px; padding: 2px 6px; display: inline-block; margin: 2px 0; }
.pron-item .pron-tip  { font-size: 12px; color: #666; }
.speak-btn {
  background: var(--purple); color: white; border: none;
  border-radius: 999px; padding: 5px 12px; font-size: 12px;
  font-weight: 700; cursor: pointer; margin-top: 4px;
  font-family: 'Nunito', sans-serif; transition: all 0.2s;
}
.speak-btn:hover { background: var(--deep); transform: scale(1.05); }

/* ═══ DIALOGUE ═══ */
.dialogue-box {
  background: var(--lav1); border-radius: 18px;
  padding: 20px; margin: 12px 0; border: 2px solid var(--lav3);
}
.dialogue-line {
  display: flex; gap: 12px; align-items: flex-start;
  margin-bottom: 14px;
}
.dialogue-line:last-child { margin-bottom: 0; }
.dialogue-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
.av-staff { background: linear-gradient(135deg, var(--purple), var(--pink)); }
.av-duda  { background: linear-gradient(135deg, var(--mint), #059669); }
.dialogue-bubble {
  flex: 1; border-radius: 16px;
  padding: 10px 14px; font-size: 15px; font-weight: 600;
  line-height: 1.5; position: relative;
}
.bubble-staff { background: white; border: 2px solid var(--lav3); color: var(--textd); }
.bubble-duda  { background: linear-gradient(135deg, var(--purple), var(--deep)); color: white; }
.bubble-pt { font-size: 12px; opacity: 0.7; font-style: italic; margin-top: 4px; display: block; }
.dialogue-label { font-size: 11px; font-weight: 800; color: var(--purple); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }

/* ═══ PHRASE CARDS ═══ */
.phrase-list { display: flex; flex-direction: column; gap: 10px; margin-top: 12px; }
.phrase-row {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 10px; align-items: center;
  background: var(--lav1); border-radius: 14px; padding: 12px 16px;
  border: 2px solid var(--lav2);
}
.phrase-row .en { font-weight: 800; color: var(--deep); font-size: 15px; }
.phrase-row .pt { color: #777; font-size: 13px; font-style: italic; }
.phrase-row .pron-badge {
  font-size: 11px; font-family: monospace; background: var(--purple);
  color: white; border-radius: 6px; padding: 2px 6px; display: inline-block; margin-left: 6px;
}

/* ═══ GAMES ═══ */
.game-area {
  background: var(--lav1); border-radius: 20px;
  padding: 22px; border: 2.5px dashed var(--purple);
  margin: 14px 0;
}
.game-area h3 { margin-top: 0; }

/* Match game */
.match-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
.match-col { display: flex; flex-direction: column; gap: 8px; }
.match-item {
  background: white; border: 2.5px solid var(--lav3);
  border-radius: 12px; padding: 10px 14px;
  cursor: pointer; text-align: center;
  font-weight: 700; font-size: 15px;
  transition: all 0.2s ease;
  user-select: none;
}
.match-item:hover { border-color: var(--purple); background: var(--lav1); }
.match-item.selected { border-color: var(--purple); background: var(--lav2); color: var(--deep); }
.match-item.matched   { border-color: #10b981; background: var(--mint2); color: #065f46; }
.match-item.wrong     { border-color: #ef4444; background: #fee2e2; animation: shake 0.3s; }
@keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)} }

/* Fill blank */
.fillblank-list { display: flex; flex-direction: column; gap: 14px; margin-top: 14px; }
.fillblank-q {
  background: white; border: 2px solid var(--lav3);
  border-radius: 14px; padding: 14px 18px;
}
.fillblank-q p { font-size: 16px; font-weight: 600; color: var(--textd); margin-bottom: 8px; }
.fillblank-q input {
  border: 2.5px solid var(--lav3); border-radius: 10px;
  padding: 8px 14px; font-size: 15px; font-family: 'Nunito',sans-serif;
  font-weight: 700; color: var(--deep); background: var(--lav1);
  width: 100%; max-width: 320px;
}
.fillblank-q input:focus { outline: none; border-color: var(--purple); background: white; }
.fillblank-q input.correct { border-color: #10b981; background: var(--mint2); }
.fillblank-q input.wrong   { border-color: #ef4444; background: #fee2e2; }
.fillblank-q .hint { font-size: 12px; color: var(--purple); margin-top: 4px; font-style: italic; }
.fillblank-q .answer-reveal { font-size: 13px; font-weight: 800; color: #10b981; margin-top: 4px; display: none; }

/* Word Scramble */
.scramble-box {
  background: white; border: 2.5px solid var(--lav3);
  border-radius: 16px; padding: 20px; margin-top: 14px;
}
.scrambled-word {
  display: flex; gap: 8px; flex-wrap: wrap;
  margin: 14px 0; justify-content: center;
}
.letter-tile {
  background: linear-gradient(135deg, var(--purple), var(--deep));
  color: white; border-radius: 10px; width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fredoka One', cursive; font-size: 22px;
  box-shadow: 0 3px 10px rgba(109,40,217,0.3);
  cursor: grab; user-select: none;
}
.scramble-answer {
  font-family: 'Fredoka One', cursive; font-size: 20px;
  color: var(--deep); background: var(--lav1);
  border-radius: 10px; padding: 8px 16px;
  display: inline-block; margin-top: 8px; display: none;
}

/* Memory game */
.memory-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 10px; margin-top: 14px; max-width: 480px; margin-left: auto; margin-right: auto;
}
.mem-card {
  aspect-ratio: 1; border-radius: 14px;
  border: 2.5px solid var(--lav3);
  background: linear-gradient(135deg, var(--deep), var(--purple));
  display: flex; align-items: center; justify-content: center;
  font-size: 32px; cursor: pointer;
  transition: transform 0.3s ease;
  user-select: none; position: relative;
  box-shadow: 0 3px 10px rgba(109,40,217,0.2);
}
.mem-card .back { font-size: 28px; position: absolute; opacity: 0; transition: opacity 0.3s; }
.mem-card .front-icon { color: white; font-size: 28px; opacity: 1; transition: opacity 0.3s; }
.mem-card.flipped { background: white; border-color: var(--purple); }
.mem-card.flipped .back  { opacity: 1; }
.mem-card.flipped .front-icon { opacity: 0; }
.mem-card.matched { background: var(--mint2); border-color: #10b981; cursor: default; }

/* Order builder */
.order-builder {
  background: white; border: 2.5px solid var(--lav3);
  border-radius: 18px; padding: 20px; margin-top: 14px;
}
.word-chips {
  display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0;
  min-height: 48px; padding: 8px; border-radius: 12px;
}
.word-chip {
  background: linear-gradient(135deg, var(--purple), var(--deep));
  color: white; border-radius: 999px; padding: 7px 16px;
  font-weight: 700; font-size: 14px; cursor: pointer;
  transition: all 0.2s; user-select: none;
  box-shadow: 0 2px 8px rgba(109,40,217,0.3);
}
.word-chip:hover { transform: scale(1.06); }
.word-chip.placed { background: var(--mint); color: #065f46; }
.word-chip.used { opacity: 0.35; cursor: default; pointer-events: none; }
.answer-slot {
  background: var(--lav1); border: 2px dashed var(--purple);
  border-radius: 12px; padding: 10px 14px; min-height: 48px;
  display: flex; flex-wrap: wrap; gap: 8px; margin: 8px 0;
}
.placed-chip {
  background: var(--lav2); color: var(--deep);
  border: 2px solid var(--purple); border-radius: 999px;
  padding: 6px 14px; font-weight: 700; font-size: 14px;
  cursor: pointer;
}
.placed-chip:hover { background: var(--coral); border-color: #ef4444; }

/* Writing ═══ */
.write-box {
  background: white; border: 2.5px solid var(--lav3);
  border-radius: 16px; padding: 20px; margin: 10px 0;
}
.write-box textarea {
  width: 100%; min-height: 90px;
  border: 2px solid var(--lav3); border-radius: 12px;
  padding: 12px; font-family: 'Nunito', sans-serif;
  font-size: 15px; resize: vertical; background: var(--lav1);
  color: var(--textd); font-weight: 600;
}
.write-box textarea:focus { outline: none; border-color: var(--purple); background: white; }
.write-box textarea::placeholder { color: #aaa; font-weight: 400; }
.write-prompt {
  font-size: 16px; font-weight: 700; color: var(--deep);
  margin-bottom: 10px; line-height: 1.5;
}
.write-hint {
  font-size: 13px; color: var(--purple); margin-top: 6px;
  background: var(--lav1); border-radius: 8px; padding: 6px 10px;
  border-left: 4px solid var(--purple);
}

/* Buttons ═══ */
button { font-family: 'Nunito', sans-serif; cursor: pointer; border: none; }
.btn {
  display: inline-block; padding: 10px 22px; border-radius: 999px;
  font-weight: 800; font-size: 14px; transition: all 0.2s ease;
  box-shadow: 0 3px 12px rgba(0,0,0,0.15); letter-spacing: 0.3px;
}
.btn:hover { transform: translateY(-2px); filter: brightness(1.08); box-shadow: 0 6px 18px rgba(0,0,0,0.2); }
.btn-purple { background: linear-gradient(135deg, var(--deep), var(--purple)); color: white; }
.btn-pink   { background: linear-gradient(135deg, #c026d3, var(--pink)); color: white; }
.btn-mint   { background: linear-gradient(135deg, #059669, #34d399); color: white; }
.btn-yellow { background: linear-gradient(135deg, #d97706, #fbbf24); color: white; }
.btn-sm     { padding: 7px 16px; font-size: 13px; }

/* Tags ═══ */
.tag {
  display: inline-block; padding: 3px 12px; border-radius: 999px;
  font-size: 11px; font-weight: 800; letter-spacing: 0.5px; text-transform: uppercase;
}
.tag-purple { background: var(--lav2); color: var(--deep); border: 2px solid var(--lav3); }
.tag-pink   { background: #fdf4ff; color: #a21caf; border: 2px solid #e9d5ff; }
.tag-mint   { background: var(--mint2); color: #065f46; border: 2px solid var(--mint); }
.tag-yellow { background: var(--yellow2); color: #92400e; border: 2px solid var(--yellow); }

/* Menu visual ═══ */
.menu-board {
  background: linear-gradient(160deg, var(--deeper), #581c87);
  border-radius: 22px; padding: 24px; margin: 14px 0; color: white;
  box-shadow: 0 8px 32px rgba(76,29,149,0.4);
}
.menu-board h3 {
  font-family: 'Fredoka One', cursive; font-size: 24px;
  color: var(--yellow); text-align: center; margin-bottom: 18px;
}
.menu-section { margin-bottom: 18px; }
.menu-section h4 {
  font-family: 'Fredoka One', cursive; font-size: 16px;
  color: var(--pink2); margin-bottom: 8px;
  border-bottom: 1px dashed rgba(255,255,255,0.2); padding-bottom: 4px;
}
.menu-items { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px,1fr)); gap: 8px; }
.menu-item {
  background: rgba(255,255,255,0.1); border-radius: 12px;
  padding: 8px 12px; display: flex; justify-content: space-between;
  align-items: center; font-size: 14px; font-weight: 600;
  border: 1px solid rgba(255,255,255,0.15);
}
.menu-item .mi-name { display: flex; align-items: center; gap: 6px; }
.menu-item .price { color: var(--yellow); font-weight: 800; font-size: 13px; }

/* Tip box ═══ */
.tip-box {
  background: var(--yellow2); border: 2px solid var(--yellow);
  border-radius: 14px; padding: 14px 18px; margin: 12px 0;
  font-size: 14px; color: #78350f;
}
.tip-box strong { color: #92400e; }

/* Notification ═══ */
.notif {
  position: fixed; top: 18px; right: 18px;
  background: linear-gradient(135deg, var(--deep), var(--purple));
  color: white; padding: 14px 22px; border-radius: 16px;
  font-weight: 800; font-size: 15px;
  box-shadow: 0 6px 24px rgba(109,40,217,0.4);
  z-index: 9999; transition: opacity 0.4s;
  display: none; border: 2px solid var(--lav3);
}

/* Stars / XP reward ═══ */
.reward-pop {
  position: fixed; top: 50%; left: 50%;
  transform: translate(-50%,-50%) scale(0);
  background: white; border: 4px solid var(--purple);
  border-radius: 28px; padding: 28px 36px; text-align: center;
  z-index: 10000; box-shadow: 0 16px 60px rgba(109,40,217,0.4);
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  max-width: 320px;
}
.reward-pop.show { transform: translate(-50%,-50%) scale(1); }
.reward-pop .stars-big { font-size: 36px; }
.reward-pop h3 { font-family: 'Fredoka One', cursive; font-size: 26px; color: var(--deep); margin: 8px 0 4px; }
.reward-pop p  { font-size: 15px; color: #666; margin-bottom: 16px; }
.overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.3); z-index: 9999; display: none; }

/* Timer ═══ */
.timer-display {
  font-family: 'Fredoka One', cursive;
  font-size: 52px; color: var(--deep); text-align: center;
  letter-spacing: 2px; margin: 8px 0;
}
.timer-display.warn { color: #dc2626; animation: pulse 0.7s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* Roleplay scenario ═══ */
.scenario-box {
  background: linear-gradient(135deg, var(--lav1), var(--pink3));
  border: 2.5px solid var(--pink);
  border-radius: 18px; padding: 20px; margin: 14px 0;
}
.scenario-scene {
  font-weight: 800; color: var(--deep); font-size: 15px;
  background: white; border-radius: 10px; padding: 8px 14px;
  border-left: 4px solid var(--purple); margin-bottom: 14px;
}

/* Responsive ═══ */
@media (max-width: 680px) {
  .vocab-grid { grid-template-columns: repeat(3,1fr); }
  .match-grid { grid-template-columns: 1fr; }
  .memory-grid { grid-template-columns: repeat(3,1fr); }
  .phrase-row { grid-template-columns: 1fr; }
  .header h1 { font-size: 34px; }
  .pron-grid { grid-template-columns: 1fr; }
}

/* Confetti bits ═══ */
.confetti-container {
  position: fixed; inset: 0; pointer-events: none; z-index: 8000;
}
.confetti-piece {
  position: absolute; width: 10px; height: 10px; border-radius: 2px;
  animation: confettiFall 2.5s ease-in forwards;
}
@keyframes confettiFall {
