// ════════════════════════════════════════
// MEMORY GAME
// ════════════════════════════════════════
const memPairs = [
  {word:'Coffee',    sym:'☕'},
  {word:'Muffin',    sym:'🧁'},
  {word:'Tea',       sym:'🍵'},
  {word:'Cookie',    sym:'🍪'},
  {word:'Water',     sym:'💧'},
  {word:'Cake',      sym:'🍰'},
];
let memFlipped=[], memMatched=0, memLocked=false;
function initMemory() {
  memFlipped=[]; memMatched=0; memLocked=false;
  document.getElementById('mem-pairs').textContent='0';
  const grid = document.getElementById('memory-grid');
  grid.innerHTML='';
  const cards = [];
  memPairs.forEach(p => {
    cards.push({type:'word',label:p.word, match:p.word});
    cards.push({type:'sym', label:p.sym,  match:p.word});
  });
  cards.sort(()=>Math.random()-0.5);
  cards.forEach((c,i)=>{
    const div = document.createElement('div');
    div.className='mem-card';
    div.dataset.match=c.match;
    div.dataset.idx=i;
    div.innerHTML=`<span class="front-icon">❓</span><span class="back">${c.label}</span>`;
    div.onclick=()=>flipMem(div);
    grid.appendChild(div);
  });
}
function flipMem(card) {
  if (memLocked || card.classList.contains('flipped') || card.classList.contains('matched')) return;
  card.classList.add('flipped');
  memFlipped.push(card);
  if (memFlipped.length===2) {
    memLocked=true;
    setTimeout(()=>{
      if (memFlipped[0].dataset.match===memFlipped[1].dataset.match) {
        memFlipped.forEach(c=>c.classList.add('matched'));
        memMatched++;
        document.getElementById('mem-pairs').textContent=memMatched;
        if (memMatched===memPairs.length) { addXP(20,'memory'); showReward('🃏🌟🎊','Memory Master!','Perfect match! You have a great memory, Duda! 🧠'); }
      } else {
        memFlipped.forEach(c=>c.classList.remove('flipped'));
      }
      memFlipped=[]; memLocked=false;
    }, 900);
  }
}

// ════════════════════════════════════════
// MATCH GAME
// ════════════════════════════════════════
let matchSelected=null, matchScore=0;
function initMatch() {
  matchSelected=null; matchScore=0;
  document.getElementById('match-score').textContent='Score: 0 / '+matchPairs.length;
  const left=document.getElementById('match-left');
  const right=document.getElementById('match-right');
  left.innerHTML=''; right.innerHTML='';
  const enItems=[...matchPairs].sort(()=>Math.random()-0.5);
  const ptItems=[...matchPairs].sort(()=>Math.random()-0.5);
  enItems.forEach(p=>{
    const d=document.createElement('div'); d.className='match-item';
    d.textContent=p.en; d.dataset.key=p.en; d.dataset.side='en';
    d.onclick=()=>selectMatch(d,'en');
    left.appendChild(d);
  });
  ptItems.forEach(p=>{
    const d=document.createElement('div'); d.className='match-item';
    d.textContent=p.pt; d.dataset.key=p.en; d.dataset.side='pt';
    d.onclick=()=>selectMatch(d,'pt');
    right.appendChild(d);
  });
}
function selectMatch(el, side) {
  if (el.classList.contains('matched')) return;
  if (!matchSelected) {
    document.querySelectorAll('.match-item').forEach(i=>i.classList.remove('selected'));
    el.classList.add('selected'); matchSelected=el; return;
  }
  if (matchSelected.dataset.side===side) {
    matchSelected.classList.remove('selected');
    el.classList.add('selected'); matchSelected=el; return;
  }
  if (matchSelected.dataset.key===el.dataset.key) {
    matchSelected.classList.remove('selected'); matchSelected.classList.add('matched');
    el.classList.add('matched');
    matchScore++; document.getElementById('match-score').textContent='Score: '+matchScore+' / '+matchPairs.length;
    if (matchScore===matchPairs.length) { addXP(20,'match'); showReward('🔗✨🌟','Perfect Match!','All pairs found! Incredible, Duda! 💜'); }
  } else {
    [matchSelected,el].forEach(i=>{ i.classList.add('wrong'); setTimeout(()=>{ i.classList.remove('wrong','selected'); },700); });
  }
  matchSelected=null;
}

